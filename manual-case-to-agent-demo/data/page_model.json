      "name": "登录页",
      "assertion": {
        "page": "LoginPage",
        "visible": {
          "strategy": "accessibility_id",
          "value": "btn_login"
        }
      },
      "controls": {
        "PhoneInput": {
          "name": "手机号输入框",
          "aliases": ["手机号", "手机号码"],
          "role": "input",
          "locator": {
            "strategy": "accessibility_id",
            "value": "input_phone"
          }
        },
        "PasswordInput": {
          "name": "密码输入框",
          "aliases": ["密码"],
          "role": "input",
          "locator": {
            "strategy": "accessibility_id",
            "value": "input_password"
          }
        },
        "LoginButton": {
          "name": "登录按钮",
          "aliases": ["登录按钮", "点击登录"],
          "role": "button",
          "locator": {
            "strategy": "accessibility_id",
            "value": "btn_login"
          }
        },
        "CaptchaImage": {
          "name": "图形验证码",
          "aliases": ["图形验证码", "验证码"],
          "role": "image",
          "locator": {
            "strategy": "accessibility_id",
            "value": "captcha_image"
          }
        }
      }
    }
  },
  "aliases": {
    "pages": {
      "首页": "HomePage",
      "我的": "ProfilePage",
      "我的页面": "ProfilePage",
      "个人中心": "ProfilePage",
      "设置": "SettingsPage",
      "设置页": "SettingsPage",
      "优惠券中心": "CouponCenterPage",
      "领券中心": "CouponCenterPage",
      "订单列表": "OrderListPage",
      "订单详情": "OrderDetailPage",
      "订单详情页": "OrderDetailPage",
      "退款申请页": "RefundPage",
      "登录页": "LoginPage"
    }
  },
  "transitions": [
    {
      "from": "HomePage",
      "to": "ProfilePage",
      "via": "ProfileTab",
      "action": "tap"
    },
    {
      "from": "ProfilePage",
      "to": "SettingsPage",
      "via": "SettingsEntry",
      "action": "tap"
    },
    {
      "from": "HomePage",
      "to": "CouponCenterPage",
      "via": "CouponCenterEntry",
      "action": "tap"
    },
    {
      "from": "HomePage",
      "to": "OrderListPage",
      "via": "OrderListEntry",
      "action": "tap"
    },
    {
      "from": "OrderListPage",
      "to": "OrderDetailPage",
      "via": "OrderItem",
      "action": "tap"
    },
    {
      "from": "OrderDetailPage",
      "to": "RefundPage",
      "via": "ApplyRefundButton",
      "action": "tap"
    }
  ],
  "backMap": {
    "SettingsPage": "ProfilePage",
    "ProfilePage": "HomePage",
    "CouponCenterPage": "HomePage",
    "RefundPage": "OrderDetailPage",
    "OrderDetailPage": "OrderListPage",
    "OrderListPage": "HomePage",
    "LoginPage": "HomePage"
  }
}
