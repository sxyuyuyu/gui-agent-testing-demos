      "assertion": {
        "page": "CouponCenterPage",
        "visible": {
          "strategy": "accessibility_id",
          "value": "btn_receive_coupon"
        }
      },
      "controls": {
        "ReceiveCouponButton": {
          "name": "立即领取按钮",
          "aliases": ["立即领取", "领取", "领券"],
          "role": "button",
          "locator": {
            "strategy": "accessibility_id",
            "value": "btn_receive_coupon"
          }
        },
        "CouponCard": {
          "name": "优惠券卡片",
          "aliases": ["优惠券", "优惠券卡片", "可领取优惠券"],
          "role": "card",
          "locator": {
            "strategy": "accessibility_id",
            "value": "coupon_card"
          }
        }
      }
    },
    "OrderListPage": {
      "name": "订单列表",
      "assertion": {
        "page": "OrderListPage",
        "visible": {
          "strategy": "accessibility_id",
          "value": "order_item"
        }
      },
      "controls": {
        "OrderItem": {
          "name": "订单条目",
          "aliases": ["订单", "第一笔订单", "已支付订单"],
          "role": "list_item",
          "locator": {
            "strategy": "accessibility_id",
            "value": "order_item"
          }
        }
      }
    },
    "OrderDetailPage": {
      "name": "订单详情页",
      "assertion": {
        "page": "OrderDetailPage",
        "visible": {
          "strategy": "accessibility_id",
          "value": "btn_apply_refund"
        }
      },
      "controls": {
        "ApplyRefundButton": {
          "name": "申请退款按钮",
          "aliases": ["申请退款", "退款"],
          "role": "button",
          "locator": {
            "strategy": "accessibility_id",
            "value": "btn_apply_refund"
          }
        }
      }
    },
    "RefundPage": {
      "name": "退款申请页",
      "assertion": {
        "page": "RefundPage",
        "visible": {
          "strategy": "accessibility_id",
          "value": "btn_submit_refund"
        }
      },
      "controls": {
        "RefundReasonSelector": {
          "name": "退款原因选择器",
          "aliases": ["退款原因", "选择退款原因"],
          "role": "select",
          "locator": {
            "strategy": "accessibility_id",
            "value": "select_refund_reason"
          }
        },
        "SubmitRefundButton": {
          "name": "提交退款按钮",
          "aliases": ["提交", "提交退款"],
          "role": "button",
          "locator": {
            "strategy": "accessibility_id",
            "value": "btn_submit_refund"
          }
        },
        "RefundStatusLabel": {
          "name": "退款状态",
          "aliases": ["退款审核中", "订单状态", "退款状态"],
          "role": "label",
          "locator": {
            "strategy": "accessibility_id",
            "value": "label_refund_status"
          }
