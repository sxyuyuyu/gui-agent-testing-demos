{
  "defaultStartPage": "HomePage",
  "pages": {
    "HomePage": {
      "name": "首页",
      "assertion": {
        "page": "HomePage",
        "visible": {
          "strategy": "accessibility_id",
          "value": "tab_home"
        }
      },
      "controls": {
        "HomeTab": {
          "name": "首页 Tab",
          "aliases": ["首页"],
          "role": "tab",
          "locator": {
            "strategy": "accessibility_id",
            "value": "tab_home"
          }
        },
        "ProfileTab": {
          "name": "我的 Tab",
          "aliases": ["我的", "我的页面", "个人中心"],
          "role": "tab",
          "locator": {
            "strategy": "accessibility_id",
            "value": "tab_profile"
          }
        },
        "CouponCenterEntry": {
          "name": "优惠券中心入口",
          "aliases": ["优惠券中心", "领券中心"],
          "role": "entry",
          "locator": {
            "strategy": "accessibility_id",
            "value": "entry_coupon_center"
          }
        },
        "OrderListEntry": {
          "name": "订单入口",
          "aliases": ["订单", "我的订单", "订单列表"],
          "role": "entry",
          "locator": {
            "strategy": "accessibility_id",
            "value": "entry_order_list"
          }
        }
      }
    },
    "ProfilePage": {
      "name": "我的页",
      "assertion": {
        "page": "ProfilePage",
        "visible": {
          "strategy": "accessibility_id",
          "value": "entry_settings"
        }
      },
      "controls": {
        "SettingsEntry": {
          "name": "设置入口",
          "aliases": ["设置", "设置入口"],
          "role": "entry",
          "locator": {
            "strategy": "accessibility_id",
            "value": "entry_settings"
          }
        }
      }
    },
    "SettingsPage": {
      "name": "设置页",
      "assertion": {
        "page": "SettingsPage",
        "visible": {
          "strategy": "accessibility_id",
          "value": "notification_switch"
        }
      },
      "controls": {
        "NotificationSwitch": {
          "name": "通知开关",
          "aliases": ["通知开关", "消息通知", "通知"],
          "role": "switch",
          "locator": {
            "strategy": "accessibility_id",
            "value": "notification_switch"
          }
        },
        "SaveButton": {
          "name": "保存按钮",
          "aliases": ["保存", "保存设置"],
          "role": "button",
          "locator": {
            "strategy": "accessibility_id",
            "value": "btn_save_settings"
          }
        }
